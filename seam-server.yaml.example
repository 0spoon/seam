# Seam server configuration
# Copy this file to seam-server.yaml and edit as needed.

# Address to listen on.
# env: SEAM_LISTEN
listen: ":8080"

# Root data directory. User databases, notes, and templates are stored here.
# env: SEAM_DATA_DIR
data_dir: "./data"

# JWT signing secret. Required, no default. Generate with:
#   openssl rand -hex 32
# env: SEAM_JWT_SECRET
jwt_secret: ""

# Ollama API base URL.
# env: SEAM_OLLAMA_URL
ollama_base_url: "http://localhost:11434"

# ChromaDB API URL. Optional; required for semantic search (Phase 2+).
# env: SEAM_CHROMADB_URL
chromadb_url: "http://localhost:8000"

# AI model names used by Seam.
# Embedding model always runs on local Ollama regardless of LLM provider.
# Chat and background models use the configured LLM provider.
models:
  embeddings: "qwen3-embedding:8b"
  background: "qwen3:32b"
  chat: "qwen3:32b"

# LLM provider for chat completions (writing assist, synthesis, suggestions, etc.).
# Embeddings always use local Ollama + ChromaDB regardless of this setting.
# Options: "ollama" (default), "openai", "anthropic"
# env: SEAM_LLM_PROVIDER
llm:
  provider: "ollama"

  # OpenAI settings (used when provider is "openai").
  # Also works with Azure OpenAI and OpenAI-compatible APIs (Together, Groq, etc.).
  openai:
    # WARNING: Prefer SEAM_OPENAI_API_KEY env var over setting this in a file.
    # Do not commit API keys to version control.
    api_key: ""             # env: SEAM_OPENAI_API_KEY
    base_url: ""            # optional; env: SEAM_OPENAI_BASE_URL
                            # defaults to https://api.openai.com/v1

  # Anthropic settings (used when provider is "anthropic").
  anthropic:
    # WARNING: Prefer SEAM_ANTHROPIC_API_KEY env var over setting this in a file.
    # Do not commit API keys to version control.
    api_key: ""             # env: SEAM_ANTHROPIC_API_KEY
    max_tokens: 4096        # max output tokens per request (Anthropic requires this)

# Whisper.cpp settings for voice transcription. Optional; required for voice capture.
# Install: brew install whisper-cpp
# Download model: curl -L -o ~/.local/share/seam/models/ggml-base.en.bin \
#   https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin
whisper:
  model_path: ""                    # path to ggml model file (e.g. ~/.local/share/seam/models/ggml-base.en.bin)
  binary_path: "whisper-cli"        # optional; defaults to "whisper-cli" on PATH

# Authentication settings.
auth:
  access_token_ttl: "15m"      # access token lifetime
  refresh_token_ttl: "168h"    # refresh token lifetime (7 days)
  bcrypt_cost: 12              # bcrypt hashing cost

# AI task queue settings.
ai:
  queue_workers: 1             # concurrent Ollama requests
  embedding_timeout: "60s"     # per-embedding call timeout (increase for large models)
  chat_timeout: "5m"           # per-chat call timeout (local models can take several minutes)

# Database manager settings.
userdb:
  eviction_timeout: "30m"     # unused in single-user mode (kept for compatibility)

# File watcher settings.
watcher:
  debounce_interval: "200ms"

# Scheduler settings (Phase 3): cron-based proactive jobs.
scheduler:
  enabled: true
  tick_interval: "1m"           # how often to poll for due jobs
  daily_briefing:
    enabled: true               # auto-create the default daily briefing on first start
    cron_expr: "0 8 * * *"      # 08:00 every day, server-local time
    project_slug: "briefings"   # project where briefing notes are filed
    lookback_hours: 24          # window for "recent activity" in the briefing
