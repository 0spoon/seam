# Seam server configuration
# Copy this file to seam-server.yaml and edit as needed.

# Address to listen on.
# env: SEAM_LISTEN
listen: ":8080"

# Root data directory. User databases, notes, and templates are stored here.
# env: SEAM_DATA_DIR
data_dir: "./data"

# JWT signing secret. Required, no default. Generate with:
#   openssl rand -hex 32
# env: SEAM_JWT_SECRET
jwt_secret: ""

# Ollama API base URL.
# env: SEAM_OLLAMA_URL
ollama_base_url: "http://localhost:11434"

# ChromaDB API URL. Optional; required for semantic search.
# Leave blank to disable semantic search entirely (FTS still works).
#
# Recommended: let Seam manage ChromaDB in a Docker container. Run
# `make init` and pick the "docker" option, then `make chroma-up` to
# start the container defined in docker/chroma-compose.yml. Or install
# the optional supervisor service via `make install-service` to keep
# it running across reboots.
#
# env: SEAM_CHROMADB_URL
chromadb_url: "http://localhost:8000"

# AI model names used by Seam.
# - models.embeddings is interpreted by whichever provider you set in
#   the embeddings block below (Ollama or OpenAI).
# - models.chat and models.background go through the LLM provider in the
#   llm block. Names are validated at startup against the provider so
#   that obvious mismatches (e.g. provider=openai with chat=qwen3:32b)
#   fail loudly instead of 404'ing on the first request. The check is
#   skipped when llm.openai.base_url is set, since OpenAI-compatible
#   APIs (Together, Groq, Azure, etc.) accept arbitrary model names.
models:
  embeddings: "qwen3-embedding:8b"
  background: "qwen3:32b"
  chat: "qwen3:32b"

# LLM provider for chat completions (writing assist, synthesis, suggestions, etc.).
# Independent of the embeddings provider below.
# Options: "ollama" (default), "openai", "anthropic"
# env: SEAM_LLM_PROVIDER
llm:
  provider: "ollama"

  # OpenAI settings (used when provider is "openai").
  # Also works with Azure OpenAI and OpenAI-compatible APIs (Together, Groq, etc.).
  openai:
    # WARNING: Prefer SEAM_OPENAI_API_KEY env var over setting this in a file.
    # Do not commit API keys to version control.
    api_key: ""             # env: SEAM_OPENAI_API_KEY
    base_url: ""            # optional; env: SEAM_OPENAI_BASE_URL
                            # defaults to https://api.openai.com/v1
                            # set to e.g. https://api.together.xyz/v1
                            # to use a compatible API; this also disables
                            # the chat-model-name check above.

  # Anthropic settings (used when provider is "anthropic").
  anthropic:
    # WARNING: Prefer SEAM_ANTHROPIC_API_KEY env var over setting this in a file.
    # Do not commit API keys to version control.
    api_key: ""             # env: SEAM_ANTHROPIC_API_KEY
    max_tokens: 4096        # max output tokens per request (Anthropic requires this)

# Embedding provider. Independent of llm.provider above: a user with
# Anthropic chat may legitimately want OpenAI or Ollama embeddings
# (Anthropic ships no embedding model). Defaults to "ollama".
#
# IMPORTANT: switching providers or embedding model invalidates the
# existing Chroma collection -- the new (provider, model) tuple gets
# its own collection name (see ai.CollectionName), so search will
# return nothing until you re-embed. Run `make reindex` to repopulate.
#
# Options: "ollama" (default), "openai"
# env: SEAM_EMBEDDINGS_PROVIDER
embeddings:
  provider: "ollama"

  # OpenAI settings (used when embeddings.provider is "openai").
  openai:
    # WARNING: Prefer SEAM_EMBEDDINGS_OPENAI_API_KEY env var over setting
    # this in a file. When empty, falls back to llm.openai.api_key so a
    # single key works for both chat and embeddings.
    api_key: ""             # env: SEAM_EMBEDDINGS_OPENAI_API_KEY
    base_url: ""            # env: SEAM_EMBEDDINGS_OPENAI_BASE_URL
                            # defaults to https://api.openai.com/v1
                            # falls back to llm.openai.base_url when empty
    # Optional dimensionality reduction. Zero (default) means "use the
    # model's native size". text-embedding-3-large is 3072 by default;
    # set this to e.g. 1024 to trade a small amount of quality for 3x
    # lower vector storage. Only supported by text-embedding-3-* models.
    dimensions: 0

# Whisper.cpp settings for voice transcription. Optional; required for voice capture.
# Install: brew install whisper-cpp
# Download model: curl -L -o ~/.local/share/seam/models/ggml-base.en.bin \
#   https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin
whisper:
  model_path: ""                    # path to ggml model file (e.g. ~/.local/share/seam/models/ggml-base.en.bin)
  binary_path: "whisper-cli"        # optional; defaults to "whisper-cli" on PATH

# Authentication settings.
auth:
  access_token_ttl: "15m"      # access token lifetime
  refresh_token_ttl: "168h"    # refresh token lifetime (7 days)
  bcrypt_cost: 12              # bcrypt hashing cost

# AI task queue settings.
ai:
  queue_workers: 1             # concurrent Ollama requests
  embedding_timeout: "60s"     # per-embedding call timeout (increase for large models)
  chat_timeout: "5m"           # per-chat call timeout (local models can take several minutes)

# Database manager settings.
userdb:
  eviction_timeout: "30m"     # unused in single-user mode (kept for compatibility)

# File watcher settings.
watcher:
  debounce_interval: "200ms"

# Scheduler settings (Phase 3): cron-based proactive jobs.
scheduler:
  enabled: true
  tick_interval: "1m"           # how often to poll for due jobs
  daily_briefing:
    enabled: true               # auto-create the default daily briefing on first start
    cron_expr: "0 8 * * *"      # 08:00 every day, server-local time
    project_slug: "briefings"   # project where briefing notes are filed
    lookback_hours: 24          # window for "recent activity" in the briefing
